# GreenSpot frontend environment.
#
# Local dev (recommended): leave empty so Vite proxies "/api" → http://localhost:8000
# (see vite.config.ts server.proxy).
#
# Production (Vercel): set to your Render backend origin, NO trailing slash.
# Example:
#   VITE_API_BASE=https://your-service.onrender.com
#
# Then set the same frontend origin on the backend:
#   CORS_ORIGINS=["https://greens-spot.vercel.app"]
#
# VITE_* is baked in at build time — after changing it on Vercel, Redeploy.
VITE_API_BASE=

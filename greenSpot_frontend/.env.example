# GreenSpot frontend environment.
#
# Leave VITE_API_BASE empty to use the Vite dev-server proxy (recommended for
# local development: requests to "/api" are forwarded to http://localhost:8000).
# Set it to an absolute URL to talk to a backend directly (CORS must allow the
# frontend origin — the backend already permits http://localhost:5173).
# No trailing slash. Leave empty to use the Vite dev-server proxy.
VITE_API_BASE=
